    <property>
      <code>require(['jquery', 'xwiki-meta', 'xwiki-events-bridge'], function ($, xm) {
  var serviceURL = new XWiki.Document('ReviewUIX', 'SOPManager.Code').getURL('get');
  $('#SOPReviewPagespane').on('click', '.reviewActions button', function(event) {
    event.preventDefault();
    var action = this.id;
    var button = $(this);
    var successBox = $('.reviewNotificationSuccess');
    var errorBox = $('.reviewNotificationError');
    var spinner = button.siblings('.fa-spinner');

    var data = {
      'action': action,
      'document': xm.document
    };

    // Disable the clicked button for any action to prevent multiple clicks.
    button.prop('disabled', true);
    // Show spinner only for the approve action.
    if (action === 'approve') {
      if (spinner.length) {
        spinner.removeClass('hidden');
      }
    }

    $.post({
      url: serviceURL,
      data: data
    }).done(function (data) {
      var successBoxContent = successBox.find('.box div p');
      successBoxContent.text(data.message);
      successBox.toggleClass('hidden');
      if (errorBox.is(':visible')) {
        errorBox.toggleClass('hidden');
      }
      setTimeout(function () {
        const r = Math.floor(Math.random() * 100);
        window.location = window.location.pathname + '?r=' + r + '#SOPReviewPages';
      }, 3000);
    }).fail(function (xhr) {
      var errorBoxContent = errorBox.find('.box div p');
      errorBoxContent.text(xhr.responseJSON.message);
      errorBox.toggleClass('hidden');
      if (successBox.is(':visible')) {
        successBox.toggleClass('hidden');
      }
    }).always(function () {
      // Always hide spinner and re-enable the button.
      if (spinner.length) {
        spinner.addClass('hidden');
      }
      button.prop('disabled', false);
    });
  });
});</code>
