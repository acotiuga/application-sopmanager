## The object to display.
#set ($xobject = $doc.getObject('SOPManager.Code.ControlledDocumentClass'))
#set ($isInReview = $xobject.getValue('isInReview') == 1)
#if ($xobject &amp;&amp; $isInReview)
  #set ($discard = $xwiki.jsx.use('SOPManager.Code.ReviewUIX'))
  #set ($discard = $xwiki.ssx.use('SOPManager.Code.ReviewUIX'))
  {{html clean="false" wiki="true"}}
    &lt;div class="row"&gt;
      &lt;div class="col-md-6"&gt;
        ## Load the JavaScript code required to make the object properties editable in-place.
        #set ($discard = $xwiki.jsfx.use('uicomponents/edit/editableProperty.js', {
          'forceSkinAction': true,
          'language': $xcontext.locale
        }))
        #set ($editing = $xcontext.action == 'edit')
        ## The class that describes the object properties.
        #set ($xclass = $xobject.xWikiClass)
        ## Make sure the following display* method calls use the right object.
        #set ($discard = $doc.use($xobject))
        ## Using the xform vertical form layout.
        &lt;div class="xform"&gt;
          &lt;dl&gt;
          #set ($generalEditing = $editing)
          #set ($propertiesToDisplay = [])
          #set ($hiddenFields = ['status', 'previousRevisions', 'revisionOwner', 'isInReview'])
          #set ($readOnlyFields = ['pDFSecondaryTargetLocation', 'revisionNumber'])
          ## Do not display status or previousRevisions.
          ## When in draft state, also hide approvedBy.
          #foreach ($property in $xclass.properties)
            #set ($name = $property.name)
            #if (!$hiddenFields.contains($name))
              #set ($discard = $propertiesToDisplay.add($property))
            #end
          #end
          #foreach ($property in $propertiesToDisplay)
            ## This property is read‑only and cannot be modified by the user.
            #if ($readOnlyFields.contains($property.name))
              #set ($editing = 'false')
            #else
              #set ($editing = $generalEditing)
            #end
            &lt;dt #if (!$editing &amp;&amp; $hasEdit)
                class="editableProperty"
                #set ($xobjectPropertyReference = $xobject.getPropertyReference($property.name))
                data-property="$escapetool.xml($services.model.serialize($xobjectPropertyReference))"
                data-property-type="object"#end&gt;
              ## This must match the id generated by the $doc.display() method below.
              #set ($propertyId = "${xclass.name}_${xobject.number}_$property.name")
              &lt;label#if ($editing) for="$escapetool.xml($propertyId)"#end&gt;
                $escapetool.xml($property.translatedPrettyName)
              &lt;/label&gt;
              ## Support for specifying a translation key as hint in the property definition.
              &lt;span class="xHint"&gt;$!escapetool.xml($services.localization.render($property.hint))&lt;/span&gt;
            &lt;/dt&gt;
            &lt;dd&gt;$doc.display($property.name)&lt;/dd&gt;
          #end
          #if (!$xclass.properties || $xclass.properties.size() == 0)
            ## Keep the empty definition term in order to have valid HTML.
            &lt;dt&gt;&lt;/dt&gt;
            &lt;dd&gt;$escapetool.xml($services.localization.render('xclass.defaultObjectSheet.noProperties'))&lt;/dd&gt;
          #end
          &lt;/dl&gt;
        &lt;/div&gt;
      &lt;/div&gt;
      &lt;div class="col-md-6 reviewActions"&gt;
        #if ("$!xobject.getValue('previousRevisions')" != '')
          &lt;div class="xform"&gt;
            &lt;dl&gt;
              &lt;dt&gt;&lt;label&gt;$escapetool.xml($services.localization.render('sopManager.reviewPage.previousRevisions.label'))&lt;label&gt;&lt;dt&gt;
              #foreach ($version in $jsontool.fromString($xobject.getValue('previousRevisions')))
                &lt;p&gt;&lt;a href="$escapetool.xml($xwiki.getURL($version.get('url')))"&gt;$escapetool.xml($version.get('url'))&lt;/a&gt;&lt;/p&gt;
              #end
              &lt;dd&gt;&lt;/dd&gt;
            &lt;/dl&gt;
          &lt;/div&gt;
        #end
        ## Add the review process actions buttons here.
        #if ($hasEdit)
          #set ($status = $xobject.getValue('status'))
          #if ($status == 'draft' || $status == 'returnedForChanges')
            &lt;button class="btn btn-default" title="$escapetool.xml($services.localization.render('sopManager.reviewPage.submitForReview.title'))" id="submitForReview"&gt;
              $escapetool.xml($services.localization.render('sopManager.reviewPage.submitForReview.label'))
            &lt;/button&gt;
          #elseif ($status == 'submittedForReview')
            &lt;button class="btn btn-default" title="$escapetool.xml($services.localization.render('sopManager.reviewPage.submitForApproval.title'))" id="submitForApproval"&gt;
              $escapetool.xml($services.localization.render('sopManager.reviewPage.submitForApproval.label'))
            &lt;/button&gt;
            &lt;button class="btn btn-default" title="$escapetool.xml($services.localization.render('sopManager.reviewPage.returnForChanges.title'))" id="returnForChanges"&gt;
              $escapetool.xml($services.localization.render('sopManager.reviewPage.returnForChanges.label'))
            &lt;/button&gt;
          #elseif ($status == 'submittedForApproval')
            #if (!$services.export.pdf.isServerSidePrintingAvailable())

              {{error}}$escapetool.xml($services.localization.render('sopManager.reviewPage.generatePDF.notAvailable')){{/error}}

            #end
            &lt;button class="btn btn-default" title="$escapetool.xml($services.localization.render('sopManager.reviewPage.approve.title'))" id="approve"&gt;
              $escapetool.xml($services.localization.render('sopManager.reviewPage.approve.label'))
            &lt;/button&gt;&lt;span class="hidden fa fa-spinner fa-spin"&gt;&lt;/span&gt;
            &lt;button class="btn btn-default" title="$escapetool.xml($services.localization.render('sopManager.reviewPage.returnForChanges.title'))" id="returnForChanges"&gt;
              $escapetool.xml($services.localization.render('sopManager.reviewPage.returnForChanges.label'))
            &lt;/button&gt;
          #elseif ($status == 'approved')
            &lt;button class="btn btn-default" title="$escapetool.xml($services.localization.render('sopManager.reviewPage.startNewRevision.title'))" id="startNewRevision"&gt;$escapetool.xml($services.localization.render('sopManager.reviewPage.startNewRevision.label'))&lt;/button&gt;
          #end
          &lt;div class="reviewNotifications"&gt;
            &lt;div class="hidden reviewNotificationSuccess"&gt;

              {{success}}reviewNotification{{/success}}

            &lt;/div&gt;
            &lt;div class="hidden reviewNotificationError"&gt;

              {{error}}reviewNotification{{/error}}

            &lt;/div&gt;
          &lt;/div&gt;
        #end
      &lt;/div&gt;
    &lt;/div&gt;
  {{/html}}
#end
{{/velocity}}</content>
