    #else
      #set ($sep = $message.indexOf(': '))
      #if ($sep &gt; -1)
        #set ($prefix = $message.substring(0, $sep))
        #if ($prefix.endsWith('Exception'))
          #set ($message = $message.substring($sep + 2))
        #end
      #end
    #end
  #end

  #set ($discard = $response.setStatus($statusCode))
  #jsonResponse({'message': $message})
#end
{{/velocity}}</content>
