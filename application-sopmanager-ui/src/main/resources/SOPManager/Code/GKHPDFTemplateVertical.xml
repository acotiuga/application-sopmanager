    <property>
      <code>@media print {
  @page {
  margin-top: 25mm;
  margin-right: 15mm;
  margin-bottom: 45mm;
  margin-left: 15mm;
}

  /**
   * Cover Page
   */
  .pdf-cover {
    border-top: 1px solid @nav-tabs-border-color;
    border-bottom: 1px solid @nav-tabs-border-color;
    margin-top: 3in;
  }

  .pdf-cover h1 {
    font-weight: bolder;
  }

  /**
   * Table of Contents
   */
  /* Distinguish the table of contents entries that correspond to document titles from those that correspond to headings
    found in the document content. */
  .pdf-toc &gt; ul &gt; li[data-xwiki-document-reference] {
    margin-top: 1em;

    &gt; span {
      font-weight: bolder;
    }
  }

  /**
   * Header
   */
  .pdf-chapter-name:before {
    content: string(chapter-name);
  }

  .sop-pdf-header {
    width: 100%;
    display: table;
    table-layout: fixed;
    border-bottom: 1px solid @nav-tabs-border-color;
    padding: 6mm 0 3mm 0;
    font-family: Arial, Helvetica, sans-serif;
    color: #111;
  }

  .sop-pdf-header-left,
  .sop-pdf-header-right {
    display: table-cell;
    vertical-align: bottom;
  }

  .sop-pdf-header-left {
    width: 42%;
    text-align: left;
  }

  .sop-pdf-header-right {
    width: 58%;
    text-align: right;
  }

  .sop-pdf-logo {
    max-height: 18mm;
    max-width: 70mm;
  }

  .sop-pdf-current-revision {
    font-size: 10pt;
    line-height: 1.2;
    white-space: nowrap;
    margin-bottom: 1.5mm;
  }

  .sop-pdf-current-title {
    font-size: 11pt;
    font-weight: bolder;
    line-height: 1.2;
  }
  
  .sop-pdf-footer-table {
    width: 100%;
    border-collapse: collapse;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 8pt;
    color: #111;
  }

  .sop-pdf-footer-table th,
  .sop-pdf-footer-table td {
    border: 1px solid #777;
    padding: 1.2mm 2mm;
    text-align: center;
    vertical-align: middle;
    line-height: 1.1;
  }

  .sop-pdf-footer-table th {
    font-weight: normal;
  }

  /**
   * Content
   */
  /* Marks the beginning of a new XWiki document. */
  h1[data-xwiki-document-reference] {
    /* Distinguish document titles from the rest of the level 1 headings that may appear in the document content. */
    font-weight: bolder;
    string-set: chapter-name content(text);

    /* Start each XWiki document on a new print page. */
    &amp; ~ h1[data-xwiki-document-reference] {
      break-before: page;
      /* Prevent floating to leak from one wiki page to the next. */
      clear: both;
    }
  }
}</code>
