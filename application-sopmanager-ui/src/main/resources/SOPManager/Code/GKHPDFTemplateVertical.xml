      <footer>{{velocity}}
#macro (extractDocumentNames $serializedRefs $output)
  #set ($names = [])
  #if (!$stringtool.isBlank($serializedRefs))
    #foreach ($serializedRef in $serializedRefs.split(','))
      #set ($serializedRef = $serializedRef.trim())
      #if (!$stringtool.isBlank($serializedRef))
        #set ($docRef = $services.model.resolveDocument($serializedRef))
        #set ($discard = $names.add($docRef.name))
      #end
    #end
  #end
  #set ($discard = $output.add($stringtool.join($names, ',')))
#end

#set ($controlledObj = $tdoc.getObject('SOPManager.Code.ControlledDocumentClass'))
#set ($xclass = $controlledObj.xWikiClass)

#set ($releaseDate = '')
#set ($approverGroups = '')
#set ($reviewerGroups = '')
#set ($revisionNumber = '')
#set ($plannedRevisionDate = '')

#if ($controlledObj)
  #set ($releaseDateValue = $controlledObj.getValue('releaseDate'))
  #if ($releaseDateValue)
    #set ($releaseDate = $datetool.format('dd.MM.yyyy', $releaseDateValue))
  #end

  #set ($approverGroups = $!controlledObj.getValue('approverGroups'))
  #set ($reviewerGroups = $!controlledObj.getValue('reviewerGroups'))
  #set ($revisionNumber = $!controlledObj.getValue('revisionNumber'))

  #set ($plannedRevisionDateValue = $controlledObj.getValue('revisionPlannedDate'))
  #if ($plannedRevisionDateValue)
    #set ($plannedRevisionDate = $datetool.format('dd.MM.yyyy', $plannedRevisionDateValue))
  #end
#end

#set ($fieldsToDisplay = ['releaseDate', 'approverGroups', 'reviewerGroups', 'revisionNumber', 'revisionPlannedDate'])


#set ($approverGroupsOutput = [])
#set ($reviewerGroupsOutput = [])
#extractDocumentNames($approverGroups $approverGroupsOutput)
#extractDocumentNames($reviewerGroups $reviewerGroupsOutput)
#set ($approverGroupsString = $approverGroupsOutput.get(0))
#set ($reviewerGroupsString = $reviewerGroupsOutput.get(0))

{{html clean="false"}}
&lt;table class="sop-pdf-footer-table"&gt;
  &lt;tr&gt;
    #foreach ($property in $xclass.properties)
      #if ($fieldsToDisplay.contains($property.name))
        &lt;th&gt;$escapetool.xml($property.translatedPrettyName)&lt;/th&gt;
      #end
    #end
    &lt;th&gt;$escapetool.xml($services.localization.render('sopManager.pdfExport.page'))&lt;/th&gt;
  &lt;/tr&gt;
  &lt;tr&gt;
    &lt;td&gt;$escapetool.xml($releaseDate)&lt;/td&gt;
    &lt;td&gt;$escapetool.xml($approverGroupsString)&lt;/td&gt;
    &lt;td&gt;$escapetool.xml($reviewerGroupsString)&lt;/td&gt;
    &lt;td&gt;$escapetool.xml($revisionNumber)&lt;/td&gt;
    &lt;td&gt;$escapetool.xml($plannedRevisionDate)&lt;/td&gt;
    &lt;td&gt;
      $escapetool.xml($services.localization.render('sopManager.pdfExport.page')) &lt;span class="pdf-page-number"&gt;&lt;/span&gt; / &lt;span class="pdf-page-count"&gt;&lt;/span&gt;
    &lt;/td&gt;
  &lt;/tr&gt;
&lt;/table&gt;
{{/html}}
{{/velocity}}</footer>
